import pandas as pd
import mplfinance as mpf


def get_renko_by_day(db, symbol, brick_size, target_date):
    table_name = f"renko_{symbol.lower()}"

    start_date = f"{target_date}T00:00:00"
    end_date = f"{target_date}T23:59:59"

    rows = db.execute(
        f"""
        SELECT
            close_time,
            open,
            high,
            low,
            close,
            volume
        FROM {table_name}
        WHERE brick_size = ?
          AND close_time BETWEEN ? AND ?
        ORDER BY close_time
        """,
        (brick_size, start_date, end_date)
    )



    df = pd.DataFrame([dict(row) for row in rows])

    if df.empty:
        return df

    df["Date"] = pd.to_datetime(df["close_time"])

    df["Open"] = df["open"].astype(float)
    df["High"] = df["high"].astype(float)
    df["Low"] = df["low"].astype(float)
    df["Close"] = df["close"].astype(float)
    df["Volume"] = df["volume"].astype(float)

    df = df[["Date", "Open", "High", "Low", "Close", "Volume"]]
    df = df.set_index("Date")

    return df

