def plot_renko(df_renko, title="Renko Chart"):
    if df_renko.empty:
        print("Nenhum Renko encontrado para o período.")
        return

    df_plot = df_renko.copy()

    df_plot.index = pd.date_range(
        start="2026-01-01 09:00:00",
        periods=len(df_plot),
        freq="1min"
    )

    mpf.plot(
        df_plot,
        type="candle",
        style="charles",
        title=title,
        ylabel="Preço",
        figsize=(24, 8),
        volume=False
    )


plot_renko(
    df_renko,
    title="Renko WINQ26 - 15R - 2026-06-17"
)


